{
  "manifest_version": 3,
  "name": "EngSpace Vocab Helper",
  "version": "1.0",
  "description": "Select English text → AI explain + Save to EngSpace for review",
  "permissions": ["contextMenus", "activeTab", "storage", "identity"],
  "host_permissions": ["http://localhost:5000/*", "https://localhost:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "EngSpace Vocab"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
